{
  "version": 1,
  "active_profile": "macros",
  "profiles": {
    "macros": {
      "display_name": "Macro Profile",
      "keys": {
        "1": {
          "action": "macro",
          "params": {
            "steps": [
              { "action": "app_launch", "params": { "bundle_id": "com.apple.Terminal" } },
              { "delay_ms": 500 },
              { "action": "text_type", "params": { "text": "echo hello\n", "method": "clipboard" } }
            ]
          }
        },
        "2": {
          "action": "macro",
          "params": {
            "steps": [
              { "action": "keyboard_shortcut", "params": { "modifiers": ["cmd"], "key": "c" } },
              { "delay_ms": 100 },
              { "action": "keyboard_shortcut", "params": { "modifiers": ["cmd"], "key": "v" } }
            ]
          }
        },
        "3": { "action": "none", "params": {} },
        "4": { "action": "none", "params": {} },
        "5": { "action": "none", "params": {} },
        "6": { "action": "none", "params": {} },
        "7": { "action": "none", "params": {} },
        "8": { "action": "none", "params": {} },
        "9": { "action": "none", "params": {} }
      }
    }
  },
  "auto_switch": {},
  "settings": {
    "launch_at_login": false,
    "show_osd": true
  }
}
